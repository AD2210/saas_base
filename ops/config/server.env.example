# Server setup and deployment configuration
# Copy to ops/config/server.env and adapt values per environment.

# Paths and release strategy
APP_BASE_DIR=/srv/saas
RELEASES_DIR=/srv/saas/releases
CURRENT_LINK=/srv/saas/app
APP_ROOT=/srv/saas/app
APP_HTTP_PORT=80
APP_HTTPS_PORT=443
SERVER_NAME=demo.dsn-dev.com
BASE_URI=https://demo.dsn-dev.com

# Child app routing from the mother app
DEFAULT_CHILD_APP_KEY=vault
CHILD_APP_VAULT_API_URL=https://secret-vault.dsn-dev.com
CHILD_APP_VAULT_LOGIN_URL=https://secret-vault.dsn-dev.com/login
CHILD_APP_VAULT_API_TOKEN=replace-with-secret-vault-provisioning-token
# Future child apps follow the same convention:
# CHILD_APP_<KEY>_API_URL=https://app-key.dsn-dev.com
# CHILD_APP_<KEY>_LOGIN_URL=https://app-key.dsn-dev.com/login
# CHILD_APP_<KEY>_API_TOKEN=replace-with-provisioning-token

# Stack health and restart behavior
STACK_REQUIRED_SERVICES="app db"
STACK_HEALTHCHECK_URL=http://127.0.0.1/healthz
HEALTHCHECK_URL=http://127.0.0.1/healthz
HEALTHCHECK_ATTEMPTS=6
HEALTHCHECK_SLEEP_SECONDS=5
WEEKLY_REBOOT_ONCALENDAR="Sun *-*-* 04:30:00"

# Application runtime
APP_ENV=prod
APP_DEBUG=0
COMPOSE_PROJECT_NAME=app
APP_SECRET=change-me-app-secret
APP_SECRETBOX_KEY=d13e60724269fb0aeaccf241a81b14387480f2e8b42f3669f10ac3bc2581396a
APP_ADMIN_PASSWORD=change-this-admin-password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
MAIN_DB_NAME=saas_base_main
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/${MAIN_DB_NAME}?serverVersion=16&charset=utf8
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null
MAILER_FROM=noreply@dsn-dev.com

# Deployment behavior
RUN_MIGRATIONS=true
APP_SERVICE_NAME=app
DEPLOY_PROFILE=prod
DEPLOY_EXCLUDES=".git .github tests docs .idea var/cache var/log .env .env.dev .env.test docker-compose.dev.yml"
PROD_DEPLOY_EXCLUDES="src/Debug src/DataFixtures config/routes/debug.yaml public/test.php"

# Monitoring reverse proxy (required only if ENABLE_MONITORING_PROXY=true)
ENABLE_MONITORING_PROXY=false
MONITORING_SERVER_NAME=monitor.dsn-dev.com
MONITORING_BASE_URI=https://monitor.dsn-dev.com
NETDATA_PUBLIC_URL=https://monitor.dsn-dev.com/netdata
UPTIME_KUMA_PUBLIC_URL=https://monitor.dsn-dev.com/uptime
NETDATA_PORT=19999
UPTIME_KUMA_PORT=3001
MONITORING_BASIC_AUTH_USER=DSN-ops
# Generate hash with: caddy hash-password --plaintext 'change-me'
MONITORING_BASIC_AUTH_PASSWORD_HASH=
NETDATA_UPSTREAM=127.0.0.1:19999
UPTIME_KUMA_UPSTREAM=127.0.0.1:3001
