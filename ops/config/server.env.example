# Server setup and deployment configuration
# Copy to ops/config/server.env and adapt values per environment.

# SSH hardening
SSH_PORT=22
ALLOW_ROOT_LOGIN=true
FAIL2BAN_MAXRETRY=3
FAIL2BAN_BANTIME=1h
LOG_RETENTION_DAYS=30

# Paths and release strategy
APP_BASE_DIR=/srv/saas
RELEASES_DIR=/srv/saas/releases
CURRENT_LINK=/srv/saas/current
APP_ROOT=/srv/saas/current

# Stack health and restart behavior
STACK_REQUIRED_SERVICES="app db"
STACK_HEALTHCHECK_URL=http://127.0.0.1/healthz
HEALTHCHECK_URL=http://127.0.0.1/healthz
HEALTHCHECK_ATTEMPTS=6
HEALTHCHECK_SLEEP_SECONDS=5
WEEKLY_REBOOT_ONCALENDAR="Sun *-*-* 04:30:00"

# Deployment behavior
RUN_MIGRATIONS=true
APP_SERVICE_NAME=app
DEPLOY_PROFILE=beta
DEPLOY_EXCLUDES=".git .github tests docs .idea var/cache var/log"
PROD_DEPLOY_EXCLUDES="src/Debug src/DataFixtures config/routes/debug.yaml public/test.php"

# Monitoring reverse proxy (required only if ENABLE_MONITORING_PROXY=true)
ENABLE_MONITORING_PROXY=false
MONITORING_DOMAIN=monitoring.example.com
MONITORING_BASIC_AUTH_USER=ops
# Generate hash with: caddy hash-password --plaintext 'change-me'
MONITORING_BASIC_AUTH_PASSWORD_HASH=
NETDATA_UPSTREAM=127.0.0.1:19999
UPTIME_KUMA_UPSTREAM=127.0.0.1:3001
