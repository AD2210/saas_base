# Backup configuration
# Copy to ops/config/backup.env and adapt values per environment.

# App root is needed by the backup wrapper systemd unit.
APP_ROOT=/srv/saas/app

# PostgreSQL source
# DB_SERVICE is used with `docker compose exec` from APP_ROOT.
# If you prefer targeting a fixed container name, set DB_CONTAINER instead.
DB_SERVICE=db
# DB_CONTAINER=
DB_MAIN_NAME=saas_base_main
TENANT_DB_PATTERN=db_%

# Local backup storage
BACKUP_DIR=/opt/backups/saas
BACKUP_RETENTION_DAYS=10

# Encryption and external destination
# Key file must contain only the passphrase.
BACKUP_ENCRYPTION_KEY_FILE=/etc/saas/backup.key
# Example: RCLONE_REMOTE=remote_ovh:saas-backups/prod
RCLONE_REMOTE=

# Backup schedule (systemd OnCalendar syntax)
BACKUP_ONCALENDAR=hourly
BACKUP_ENV_TARGET=/etc/saas/backup.env
