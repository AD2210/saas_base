{% extends 'base.html.twig' %}

{% block title %}{{ child_app_profile.name }}{% endblock %}

{% block body %}
    <main class="onboarding-page">
        <section class="onboarding-card">
            <p class="onboarding-eyebrow">{{ child_app_profile.onboardingEyebrow }}</p>
            <h1>{{ child_app_profile.onboardingTitle }}</h1>
            <p class="onboarding-message">{{ message }}</p>
            {% if state in ['valid', 'invalid_password'] %}
                <p class="onboarding-message onboarding-message--intro">{{ child_app_profile.onboardingLead }}</p>
            {% endif %}

            {% if state in ['invalid', 'expired'] %}
                <div class="onboarding-alert onboarding-alert--error">
                    This onboarding link cannot be used.
                </div>
            {% elseif state == 'sync_failed' %}
                <div class="onboarding-alert onboarding-alert--error">
                    Tenant app synchronization failed. Please retry.
                </div>
            {% elseif state == 'accepted' %}
                <div class="onboarding-alert onboarding-alert--success">
                    Onboarding completed successfully.
                </div>
                {% if child_app_login_url is defined and child_app_login_url %}
                    <p>
                        <a href="{{ child_app_login_url }}" class="cta">Open tenant vault login</a>
                    </p>
                {% endif %}
            {% else %}
                <form method="post" class="onboarding-form" novalidate data-turbo="false">
                    <input type="hidden" name="token" value="{{ token }}">

                    <label>
                        <span>Password</span>
                        <input type="password" name="password" minlength="12" required autocomplete="new-password">
                    </label>

                    <label>
                        <span>Confirm password</span>
                        <input type="password" name="password_confirm" minlength="12" required autocomplete="new-password">
                    </label>

                    <ul class="onboarding-rules">
                        <li>At least 12 characters</li>
                        <li>At least 1 uppercase letter</li>
                        <li>At least 1 number</li>
                        <li>At least 1 special character</li>
                    </ul>

                    {% if password_errors is defined and password_errors is not empty %}
                        <div class="onboarding-alert onboarding-alert--error">
                            <ul class="onboarding-errors">
                                {% for error in password_errors %}
                                    <li>{{ error }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <button type="submit" class="cta">Save password</button>
                </form>
            {% endif %}
        </section>
    </main>
{% endblock %}
