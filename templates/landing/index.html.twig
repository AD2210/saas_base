{% extends 'base.html.twig' %}

{% block title %}{{ child_app_profile.name }}{% endblock %}

{% block body %}
    <main class="landing-page">
        <section class="hero">
            <div class="hero__copy">
                <p class="hero__eyebrow">{{ child_app_profile.landingEyebrow }}</p>
                <h1>{{ child_app_profile.landingTitle }}</h1>
                <p class="hero__lead">{{ child_app_profile.landingLead }}</p>
                <ul class="hero__facts">
                    {% for fact in child_app_profile.landingFacts %}
                        <li>{{ fact }}</li>
                    {% endfor %}
                </ul>

                {% if child_app_profiles|length > 1 %}
                    <nav class="hero__apps" aria-label="Available child apps">
                        {% for profile in child_app_profiles %}
                            {% set profileHref = profile.key == default_child_app_key ? path('app_landing') : path('app_landing_child_app', {childAppKey: profile.key}) %}
                            <a href="{{ profileHref }}" class="hero__app-link{% if profile.key == child_app_profile.key %} hero__app-link--active{% endif %}">{{ profile.name }}</a>
                        {% endfor %}
                    </nav>
                {% endif %}
            </div>

            <div class="hero__form-card">
                <h2>{{ child_app_profile.formTitle }}</h2>
                <p class="hero__form-subtitle">{{ child_app_profile.formSubtitle }}</p>

                <form data-demo-form novalidate>
                    <input type="hidden" name="child_app_key" value="{{ child_app_profile.key }}">
                    <div class="grid two">
                        <label>
                            <span>First name</span>
                            <input type="text" name="first_name" required autocomplete="given-name">
                        </label>
                        <label>
                            <span>Last name</span>
                            <input type="text" name="last_name" required autocomplete="family-name">
                        </label>
                    </div>

                    <div class="grid two">
                        <label>
                            <span>Email</span>
                            <input type="email" name="email" required autocomplete="email">
                        </label>
                        <label>
                            <span>Phone</span>
                            <input type="tel" name="phone" required autocomplete="tel">
                        </label>
                    </div>

                    <label>
                        <span>Company</span>
                        <input type="text" name="company" required autocomplete="organization">
                    </label>

                    <label>
                        <span>Address</span>
                        <input type="text" name="address" required autocomplete="street-address">
                    </label>

                    <div class="grid two">
                        <label>
                            <span>Birth date</span>
                            <input type="date" name="birth_date" required>
                        </label>
                        <label>
                            <span>Slug (optional)</span>
                            <input type="text" name="slug" placeholder="my-tenant">
                        </label>
                    </div>

                    <button type="submit" class="cta" data-submit-button>{{ child_app_profile.submitLabel }}</button>
                </form>

                <div class="form-status" data-form-status aria-live="polite"></div>
            </div>
        </section>
    </main>
{% endblock %}
