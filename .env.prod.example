APP_ENV=prod
APP_DEBUG=0

APP_SECRET=replace-with-prod-secret
APP_SECRETBOX_KEY=replace-with-64-char-secretbox-key
APP_ADMIN_PASSWORD=replace-with-admin-password

SERVER_NAME=demo.example.com
APP_HTTP_PORT=80
APP_HTTPS_PORT=443
SHARED_EDGE_NETWORK=saas-edge

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-postgres-password
MAIN_DB_NAME=saas_base_main
DATABASE_URL="postgresql://postgres:replace-with-postgres-password@db:5432/saas_base_main?serverVersion=16&charset=utf8"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null
MAILER_FROM=noreply@example.com

DEFAULT_CHILD_APP_KEY=vault
CHILD_APP_VAULT_SERVER_NAME=secret-vault.example.com
CHILD_APP_VAULT_UPSTREAM=secret-vault-app:80
CHILD_APP_VAULT_API_URL=http://secret-vault-app
CHILD_APP_VAULT_LOGIN_URL=https://secret-vault.example.com/t/{tenantSlug}/login
CHILD_APP_VAULT_API_TOKEN=replace-with-child-app-provisioning-token

NETDATA_PUBLIC_URL=https://monitor.example.com/netdata
UPTIME_KUMA_PUBLIC_URL=https://monitor.example.com/uptime
NETDATA_PORT=19999
UPTIME_KUMA_PORT=3001
